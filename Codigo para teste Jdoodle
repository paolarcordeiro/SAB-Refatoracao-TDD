import java.util.ArrayList;
import java.util.List;

// ===== Exceções =====
class UsuarioJaRegistradoException extends Exception {
    public UsuarioJaRegistradoException(String msg) {
        super(msg);
    }
}

class UsuarioComNomeVazioException extends Exception {
    public UsuarioComNomeVazioException(String msg) {
        super(msg);
    }
}

class UsuarioInexistenteException extends Exception {
    public UsuarioInexistenteException(String msg) {
        super(msg);
    }
}

// ===== Entidade =====
class Usuario {
    private String nome;

    public Usuario(String nome) {
        this.nome = nome;
    }

    @Override
    public boolean equals(Object obj) {
        if (this == obj) return true;
        if (!(obj instanceof Usuario)) return false;
        Usuario other = (Usuario) obj;
        return nome.equals(other.nome);
    }

    @Override
    public int hashCode() {
        return nome.hashCode();
    }
}

// ===== Classe principal =====
public class Main {

    private List<Usuario> _usuarios = new ArrayList<>();

    // ✅ Método REFATORADO
    public void registraUsuario(String nome)
            throws UsuarioJaRegistradoException,
                   UsuarioComNomeVazioException,
                   UsuarioInexistenteException {

        if (nome == null)
            throw new UsuarioInexistenteException(
                "--->Não pode registrar usuario inexistente!"
            );

        if (nome.isEmpty())
            throw new UsuarioComNomeVazioException(
                "--->Não pode registrar usuario com nome vazio!"
            );

        Usuario usuario = new Usuario(nome);

        if (_usuarios.contains(usuario))
            throw new UsuarioJaRegistradoException(
                "--->Já existe usuário com o nome \"" + nome + "\"! Use outro nome!"
            );

        _usuarios.add(usuario);
    }

    // ===== main para teste =====
    public static void main(String[] args) {
    Main sistema = new Main();

    try {
        sistema.registraUsuario("Paola");
        sistema.registraUsuario("João");

        // sistema.registraUsuario("Paola"); // ← COMENTADA

    } catch (Exception e) {
        System.out.println(e.getMessage());
    }
}
}

